{
  "name": "broflo",
  "version": "0.1.0",
  "private": true,
  "description": "Broflo — AI-powered gift concierge",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter './apps/**' --parallel run dev",
    "dev:web": "pnpm --filter @broflo/web dev",
    "dev:api": "pnpm --filter @broflo/api dev",
    "build": "pnpm --filter './apps/**' run build",
    "build:web": "pnpm --filter @broflo/web build",
    "build:api": "pnpm --filter @broflo/api build",
    "lint": "pnpm --filter './apps/**' --filter './packages/**' run lint",
    "typecheck": "pnpm --filter './apps/**' --filter './packages/**' run typecheck",
    "test": "pnpm --filter './apps/**' --filter './packages/**' run test",
    "clean": "pnpm --filter './apps/**' --filter './packages/**' --filter './services/**' run clean",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "test:cross-browser": "npx playwright test --config=playwright.cross-browser.config.ts",
    "test:cross-browser:headed": "npx playwright test --config=playwright.cross-browser.config.ts --headed"
  },
  "pnpm": {
    "overrides": {
      "multer": ">=2.2.0 <3.0.0",
      "body-parser": ">=2.3.0 <3.0.0",
      "qs": ">=6.15.2 <7.0.0",
      "protobufjs": ">=8.6.0 <9.0.0",
      "@protobufjs/utf8": ">=1.1.1",
      "@grpc/grpc-js": ">=1.14.4 <2.0.0",
      "@opentelemetry/core": ">=2.8.0 <3.0.0",
      "@opentelemetry/sdk-node": ">=0.217.0",
      "@opentelemetry/exporter-prometheus": ">=0.217.0",
      "hono": ">=4.12.25 <5.0.0",
      "js-yaml": ">=4.2.0 <5.0.0",
      "@babel/core": ">=7.29.6 <8.0.0",
      "form-data": ">=4.0.6 <5.0.0",
      "minimatch@10>brace-expansion": ">=5.0.6 <6.0.0",
      "fast-uri": ">=3.1.2",
      "fast-xml-builder": ">=1.1.7",
      "fast-xml-parser": ">=5.7.0",
      "uuid": ">=13.0.1",
      "ip-address": ">=10.1.1",
      "postcss": ">=8.5.10"
    }
  },
  "devDependencies": {
    "@cu2/shared-lib": "github:credit-union-2-0-llc/cu2-shared-lib",
    "@playwright/test": "^1.59.1",
    "dotenv": "^17.4.2"
  }
}
