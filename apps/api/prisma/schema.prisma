generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  passwordHash     String?   @map("password_hash")
  refreshToken     String?   @map("refresh_token")
  resetToken       String?   @map("reset_token")
  resetTokenExpires DateTime? @map("reset_token_expires")
  googleId         String?   @unique @map("google_id")
  avatarUrl        String?   @map("avatar_url")
  subscriptionTier      String    @default("free") @map("subscription_tier")
  stripeCustomerId      String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId  String?   @unique @map("stripe_subscription_id")
  stripePaymentMethodId String?   @map("stripe_payment_method_id")
  brofloScore           Int       @default(0) @map("broflo_score")
  failedLogins     Int       @default(0) @map("failed_logins")
  lockedUntil      DateTime? @map("locked_until")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  persons          Person[]
  events           Event[]
  reminders        Reminder[]
  suggestions      GiftSuggestion[]
  giftRecords      GiftRecord[]
  aiAuditLogs      AiAuditLog[]
  orders           Order[]
  autopilotRules   AutopilotRule[]
  notifications    Notification[]
  agentJobs        AgentJob[]
  serviceCredits   ServiceCredit[]

  @@map("users")
}

model RevokedToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime @default(now()) @map("revoked_at")

  @@map("revoked_tokens")
}

model Person {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  name             String
  relationship     String
  birthday         DateTime?
  anniversary      DateTime?
  budgetMinCents   Int?      @map("budget_min_cents")
  budgetMaxCents   Int?      @map("budget_max_cents")
  clothingSizeTop  String?   @map("clothing_size_top")
  clothingSizeBottom String? @map("clothing_size_bottom")
  shoeSize         String?   @map("shoe_size")
  musicTaste       String?   @map("music_taste")
  favoriteBrands   String?   @map("favorite_brands")
  hobbies          String?
  foodPreferences  String?   @map("food_preferences")
  wishlistUrls     String?   @map("wishlist_urls")
  notes            String?
  shippingAddress1  String?   @map("shipping_address1")
  shippingAddress2  String?   @map("shipping_address2")
  shippingCity      String?   @map("shipping_city")
  shippingState     String?   @map("shipping_state")
  shippingZip       String?   @map("shipping_zip")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  pronouns          String?   @db.VarChar(50)
  allergens         String[]  @default([])
  dietaryRestrictions String[] @default([]) @map("dietary_restrictions")
  dossierInsight    String?   @map("dossier_insight") @db.VarChar(2000)
  completenessScore Int       @default(0) @map("completeness_score")

  user             User      @relation(fields: [userId], references: [id])
  neverAgainItems  NeverAgainItem[]
  events           Event[]
  suggestions      GiftSuggestion[]
  giftRecords      GiftRecord[]
  orders           Order[]
  autopilotRules   AutopilotRule[]
  tags             PersonTag[]
  wishlistItems    WishlistItem[]

  @@index([userId, deletedAt])
  @@map("persons")
}

model NeverAgainItem {
  id        String   @id @default(uuid())
  personId  String   @map("person_id")
  description String
  createdAt DateTime @default(now()) @map("created_at")

  person    Person   @relation(fields: [personId], references: [id])

  @@map("never_again_items")
}

model PersonTag {
  id        String   @id @default(uuid())
  personId  String   @map("person_id")
  tag       String   @db.VarChar(100)
  source    String   @default("ai") @db.VarChar(50) // "ai" | "manual"
  createdAt DateTime @default(now()) @map("created_at")

  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, tag], name: "uq_person_tag", map: "uq_person_tag")
  @@index([personId], map: "idx_person_tags_person")
  @@map("person_tags")
}

model WishlistItem {
  id          String   @id @default(uuid())
  personId    String   @map("person_id")
  sourceUrl   String   @map("source_url") @db.VarChar(2000)
  productName String?  @map("product_name") @db.VarChar(500)
  category    String?  @db.VarChar(200)
  brand       String?  @db.VarChar(200)
  priceRange  String?  @map("price_range") @db.VarChar(100)
  scrapedAt   DateTime @default(now()) @map("scraped_at")
  createdAt   DateTime @default(now()) @map("created_at")

  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId], map: "idx_wishlist_items_person")
  @@map("wishlist_items")
}

enum OccasionType {
  birthday
  anniversary
  holiday
  graduation
  promotion
  custom

  @@map("occasion_type")
}

enum RecurrenceRule {
  annual
  one_time @map("one_time")

  @@map("recurrence_rule")
}

model Event {
  id             String         @id @default(uuid())
  personId       String         @map("person_id")
  userId         String         @map("user_id")
  name           String
  occasionType   OccasionType   @map("occasion_type")
  date           DateTime       @db.Date
  isRecurring    Boolean        @default(false) @map("is_recurring")
  recurrenceRule RecurrenceRule @default(one_time) @map("recurrence_rule")
  budgetMinCents Int?           @map("budget_min_cents")
  budgetMaxCents Int?           @map("budget_max_cents")
  notes          String?
  isAutoCreated  Boolean        @default(false) @map("is_auto_created")
  userModified   Boolean        @default(false) @map("user_modified")
  userDeleted    Boolean        @default(false) @map("user_deleted")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  person    Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders Reminder[]
  suggestions GiftSuggestion[]
  giftRecords GiftRecord[]
  orders      Order[]
  autopilotRuns AutopilotRun[]

  @@unique([personId, occasionType, isAutoCreated], name: "uq_person_auto_event", map: "uq_person_auto_event")
  @@index([userId, date], map: "idx_events_user_date")
  @@index([personId], map: "idx_events_person")
  @@index([userId, occasionType], map: "idx_events_user_occasion")
  @@map("events")
}

model Reminder {
  id           String    @id @default(uuid())
  eventId      String    @map("event_id")
  userId       String    @map("user_id")
  leadDays     Int       @map("lead_days")
  scheduledFor DateTime  @map("scheduled_for") @db.Date
  dismissedAt  DateTime? @map("dismissed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, leadDays, scheduledFor], map: "uq_reminder_event_lead_scheduled")
  @@index([userId, dismissedAt, scheduledFor], map: "idx_reminders_user_active")
  @@map("reminders")
}

// --- S-4/S-5 Enums ---

enum GiftSource {
  suggestion
  manual
  ordered

  @@map("gift_source")
}

enum AuditStatus {
  success
  error
  timeout
  rate_limited @map("rate_limited")

  @@map("audit_status")
}

enum SurpriseFactor {
  safe
  bold

  @@map("surprise_factor")
}

// --- S-4: Gift Brain ---

model GiftSuggestion {
  id                     String         @id @default(uuid())
  personId               String         @map("person_id")
  eventId                String         @map("event_id")
  userId                 String         @map("user_id")
  title                  String
  description            String
  estimatedPriceMinCents Int            @map("estimated_price_min_cents")
  estimatedPriceMaxCents Int            @map("estimated_price_max_cents")
  reasoning              String
  confidenceScore        Float          @map("confidence_score")
  delightScore           Float          @map("delight_score")
  noveltyScore           Float          @map("novelty_score")
  retailerHint           String?        @map("retailer_hint")
  suggestedMessage       String?        @map("suggested_message")
  modelVersion           String         @map("model_version")
  promptTokens           Int            @map("prompt_tokens")
  completionTokens       Int            @map("completion_tokens")
  latencyMs              Int            @map("latency_ms")
  requestIndex           Int            @default(0) @map("request_index")
  surpriseFactor         SurpriseFactor @default(safe) @map("surprise_factor")
  guidanceText           String?        @map("guidance_text")
  isSelected             Boolean        @default(false) @map("is_selected")
  isDismissed            Boolean        @default(false) @map("is_dismissed")
  dismissalReason        String?        @map("dismissal_reason")
  expiresAt              DateTime       @map("expires_at")
  createdAt              DateTime       @default(now()) @map("created_at")

  person     Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  giftRecord GiftRecord?

  @@index([eventId, requestIndex, isDismissed], map: "idx_suggestions_event_request")
  @@index([personId, isSelected], map: "idx_suggestions_person_selected")
  @@index([userId, createdAt], map: "idx_suggestions_user_created")
  @@index([expiresAt], map: "idx_suggestions_expires")
  @@map("gift_suggestions")
}

// --- S-5: Gift History ---

model GiftRecord {
  id                 String          @id @default(uuid())
  personId           String          @map("person_id")
  eventId            String?         @map("event_id")
  userId             String          @map("user_id")
  suggestionId       String?         @unique @map("suggestion_id")
  title              String
  description        String?
  priceCents         Int?            @map("price_cents")
  givenAt            DateTime        @map("given_at") @db.Date
  rating             Int?
  feedbackNote       String?         @map("feedback_note")
  imageUrl           String?         @map("image_url")
  source             GiftSource      @default(manual)
  suggestionSnapshot Json?           @map("suggestion_snapshot")
  feedbackScored     Boolean         @default(false) @map("feedback_scored")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  person     Person          @relation(fields: [personId], references: [id], onDelete: Cascade)
  event      Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestion GiftSuggestion? @relation(fields: [suggestionId], references: [id], onDelete: SetNull)
  order      Order?

  @@index([personId, givenAt], map: "idx_gifts_person_given")
  @@index([userId, givenAt], map: "idx_gifts_user_given")
  @@index([eventId], map: "idx_gifts_event")
  @@index([personId, rating], map: "idx_gifts_person_rating")
  @@map("gift_records")
}

// --- S-7: Orders ---

enum OrderStatus {
  pending
  ordered
  processing
  shipped
  delivered
  cancelled
  failed

  @@map("order_status")
}

enum StatusChangeSource {
  system
  webhook
  manual

  @@map("status_change_source")
}

model Order {
  id                    String      @id @default(uuid())
  userId                String      @map("user_id")
  personId              String      @map("person_id")
  eventId               String?     @map("event_id")
  giftRecordId          String?     @unique @map("gift_record_id")
  suggestionId          String?     @map("suggestion_id")
  retailerKey           String      @map("retailer_key")
  retailerProductId     String      @map("retailer_product_id")
  retailerOrderId       String?     @map("retailer_order_id")
  confirmationNumber    String?     @map("confirmation_number")
  productTitle          String      @map("product_title")
  productDescription    String?     @map("product_description")
  productImageUrl       String?     @map("product_image_url")
  priceCents            Int         @map("price_cents")
  platformFeeCents      Int         @default(0) @map("platform_fee_cents")
  stripePaymentIntentId String?     @map("stripe_payment_intent_id")
  status                OrderStatus @default(pending)
  shippingName          String      @map("shipping_name")
  shippingAddress1      String      @map("shipping_address1")
  shippingAddress2      String?     @map("shipping_address2")
  shippingCity          String      @map("shipping_city")
  shippingState         String      @map("shipping_state")
  shippingZip           String      @map("shipping_zip")
  estimatedDeliveryDate DateTime?   @map("estimated_delivery_date")
  trackingNumber        String?     @map("tracking_number")
  trackingUrl           String?     @map("tracking_url")
  carrierName           String?     @map("carrier_name")
  deliveredAt           DateTime?   @map("delivered_at")
  placedAt              DateTime?   @map("placed_at")
  cancelledAt           DateTime?   @map("cancelled_at")
  cancelReason          String?     @map("cancel_reason")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  person        Person               @relation(fields: [personId], references: [id], onDelete: Cascade)
  event         Event?               @relation(fields: [eventId], references: [id], onDelete: SetNull)
  giftRecord    GiftRecord?          @relation(fields: [giftRecordId], references: [id], onDelete: SetNull)
  statusHistory OrderStatusHistory[]
  agentJob      AgentJob?

  @@index([userId, status, placedAt], map: "idx_orders_user_status")
  @@index([personId, placedAt], map: "idx_orders_person_placed")
  @@map("orders")
}

model OrderStatusHistory {
  id         String             @id @default(uuid())
  orderId    String             @map("order_id")
  fromStatus OrderStatus?       @map("from_status")
  toStatus   OrderStatus        @map("to_status")
  source     StatusChangeSource @default(system)
  metadata   Json?
  changedAt  DateTime           @default(now()) @map("changed_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, changedAt], map: "idx_order_status_history")
  @@map("order_status_history")
}

// --- S-9: Autopilot ---

enum AutopilotRunStatus {
  triggered
  order_placed  @map("order_placed")
  failed
  skipped_budget @map("skipped_budget")
  skipped_confidence @map("skipped_confidence")
  skipped_tier @map("skipped_tier")
  skipped_no_suggestion @map("skipped_no_suggestion")

  @@map("autopilot_run_status")
}

model AutopilotRule {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  personId        String    @map("person_id")
  isActive        Boolean   @default(true) @map("is_active")
  occasionTypes   String[]  @map("occasion_types")
  budgetMinCents  Int       @map("budget_min_cents")
  budgetMaxCents  Int       @map("budget_max_cents")
  monthlyCapCents Int       @map("monthly_cap_cents")
  leadDays        Int       @default(7) @map("lead_days")
  consentedAt     DateTime  @map("consented_at")
  consentedFromIp String    @map("consented_from_ip")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  person  Person          @relation(fields: [personId], references: [id], onDelete: Cascade)
  runs    AutopilotRun[]

  @@unique([userId, personId], name: "uq_autopilot_user_person", map: "uq_autopilot_user_person")
  @@index([userId, isActive], map: "idx_autopilot_user_active")
  @@map("autopilot_rules")
}

model AutopilotRun {
  id              String            @id @default(uuid())
  ruleId          String            @map("rule_id")
  eventId         String            @map("event_id")
  orderId         String?           @map("order_id")
  suggestionId    String?           @map("suggestion_id")
  status          AutopilotRunStatus
  reason          String?
  confidenceScore Float?            @map("confidence_score")
  amountCents     Int?              @map("amount_cents")
  metadata        Json?
  createdAt       DateTime          @default(now()) @map("created_at")

  rule       AutopilotRule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  event      Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([ruleId, createdAt], map: "idx_autopilot_runs_rule")
  @@index([eventId], map: "idx_autopilot_runs_event")
  @@map("autopilot_runs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String
  linkUrl   String?  @map("link_url")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt], map: "idx_notifications_user_unread")
  @@map("notifications")
}

// --- S-4: AI Audit ---

model AiAuditLog {
  id                  String      @id @default(uuid())
  userId              String      @map("user_id")
  personId            String      @map("person_id")
  eventId             String      @map("event_id")
  model               String
  tier                String
  inputTokens         Int         @map("input_tokens")
  outputTokens        Int         @map("output_tokens")
  latencyMs           Int         @map("latency_ms")
  cacheHit            Boolean     @default(false) @map("cache_hit")
  promptCacheHit      Boolean     @default(false) @map("prompt_cache_hit")
  suggestionsReturned Int         @map("suggestions_returned")
  suggestionsFiltered Int         @default(0) @map("suggestions_filtered")
  retryCount          Int         @default(0) @map("retry_count")
  status              AuditStatus
  errorMessage        String?     @map("error_message")
  createdAt           DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "idx_audit_user_created")
  @@index([createdAt], map: "idx_audit_created")
  @@index([status, createdAt], map: "idx_audit_status_created")
  @@index([model, createdAt], map: "idx_audit_model_created")
  @@index([tier, createdAt], map: "idx_audit_tier_created")
  @@map("ai_audit_logs")
}

// --- S-10: Browser Agent ---

enum AgentJobStatus {
  queued
  running
  previewing
  placing
  completed
  failed
  aborted

  @@map("agent_job_status")
}

enum AgentFailureReason {
  captcha
  out_of_stock    @map("out_of_stock")
  blocked
  timeout
  price_mismatch  @map("price_mismatch")
  payment_declined @map("payment_declined")
  address_rejected @map("address_rejected")
  unknown

  @@map("agent_failure_reason")
}

enum AgentStepAction {
  navigate
  search
  filter
  select_product   @map("select_product")
  add_to_cart      @map("add_to_cart")
  enter_address    @map("enter_address")
  enter_payment    @map("enter_payment")
  confirm_order    @map("confirm_order")
  capture_confirmation @map("capture_confirmation")
  detect_captcha   @map("detect_captcha")
  detect_oos       @map("detect_oos")
  error

  @@map("agent_step_action")
}

enum AgentStepStatus {
  pending
  running
  completed
  failed
  skipped

  @@map("agent_step_status")
}

model AgentJob {
  id                  String             @id @default(uuid())
  userId              String             @map("user_id")
  orderId             String?            @unique @map("order_id")
  suggestionId        String?            @map("suggestion_id")
  autopilotRunId      String?            @unique @map("autopilot_run_id")
  status              AgentJobStatus     @default(queued)
  retailerDomain      String             @map("retailer_domain")
  retailerUrl         String             @map("retailer_url")
  searchTerms         String             @map("search_terms")
  maxBudgetCents      Int                @map("max_budget_cents")
  shippingName        String             @map("shipping_name")
  shippingAddress1    String             @map("shipping_address1")
  shippingAddress2    String?            @map("shipping_address2")
  shippingCity        String             @map("shipping_city")
  shippingState       String             @map("shipping_state")
  shippingZip         String             @map("shipping_zip")
  foundProductTitle   String?            @map("found_product_title")
  foundProductPrice   Int?               @map("found_product_price")
  foundProductUrl     String?            @map("found_product_url")
  foundProductImage   String?            @map("found_product_image")
  matchConfidence     Float?             @map("match_confidence")
  confirmationNumber  String?            @map("confirmation_number")
  browserSessionId    String?            @map("browser_session_id")
  stripeVirtualCardId String?            @map("stripe_virtual_card_id")
  failureReason       AgentFailureReason? @map("failure_reason")
  retryCount          Int                @default(0) @map("retry_count")
  maxRetries          Int                @default(2) @map("max_retries")
  idempotencyKey      String             @unique @map("idempotency_key")
  startedAt           DateTime?          @map("started_at")
  completedAt         DateTime?          @map("completed_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  order   Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  steps   AgentStep[]

  @@index([userId, status], map: "idx_agent_jobs_user_status")
  @@index([status, createdAt], map: "idx_agent_jobs_status_queue")
  @@index([retailerDomain, status], map: "idx_agent_jobs_retailer")
  @@map("agent_jobs")
}

model AgentStep {
  id              String           @id @default(uuid())
  jobId           String           @map("job_id")
  stepNumber      Int              @map("step_number")
  action          AgentStepAction
  status          AgentStepStatus  @default(pending)
  screenshotUrl   String?          @map("screenshot_url")
  pageUrl         String?          @map("page_url")
  aiModelUsed     String?          @map("ai_model_used")
  aiConfidence    Float?           @map("ai_confidence")
  metadata        Json?
  startedAt       DateTime?        @map("started_at")
  completedAt     DateTime?        @map("completed_at")

  job AgentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, stepNumber], name: "uq_agent_step_job_number", map: "uq_agent_step_job_number")
  @@index([jobId, stepNumber], map: "idx_agent_steps_job")
  @@map("agent_steps")
}

model RetailerProfile {
  id               String    @id @default(uuid())
  retailerDomain   String    @unique @map("retailer_domain")
  displayName      String    @map("display_name")
  supported        Boolean   @default(true)
  searchUrlPattern String?   @map("search_url_pattern")
  captchaRate      Float     @default(0) @map("captcha_rate")
  successRate      Float     @default(1) @map("success_rate")
  totalAttempts    Int       @default(0) @map("total_attempts")
  totalSuccesses   Int       @default(0) @map("total_successes")
  avgExecutionMs   Int       @default(0) @map("avg_execution_ms")
  lastAttemptAt    DateTime? @map("last_attempt_at")
  blockedSince     DateTime? @map("blocked_since")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("retailer_profiles")
}

model ServiceCredit {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  agentJobId      String?  @map("agent_job_id")
  amountCents     Int      @map("amount_cents")
  reason          String
  stripeCouponId  String?  @map("stripe_coupon_id")
  billingCycleKey String   @map("billing_cycle_key")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, billingCycleKey], name: "uq_service_credit_user_cycle", map: "uq_service_credit_user_cycle")
  @@index([userId, createdAt], map: "idx_service_credits_user")
  @@map("service_credits")
}

model FailureReview {
  id              String    @id @default(uuid())
  agentJobId      String    @map("agent_job_id")
  retailerDomain  String    @map("retailer_domain")
  failureReason   String    @map("failure_reason")
  isSystemic      Boolean?  @map("is_systemic")
  reviewNotes     String?   @map("review_notes")
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([resolvedAt, createdAt], map: "idx_failure_reviews_unresolved")
  @@index([retailerDomain], map: "idx_failure_reviews_retailer")
  @@map("failure_reviews")
}
