generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  passwordHash     String?   @map("password_hash")
  refreshToken     String?   @map("refresh_token")
  resetToken       String?   @map("reset_token")
  resetTokenExpires DateTime? @map("reset_token_expires")
  googleId         String?   @unique @map("google_id")
  avatarUrl        String?   @map("avatar_url")
  subscriptionTier String    @default("free") @map("subscription_tier")
  brofloScore      Int       @default(0) @map("broflo_score")
  failedLogins     Int       @default(0) @map("failed_logins")
  lockedUntil      DateTime? @map("locked_until")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  persons          Person[]
  events           Event[]
  reminders        Reminder[]

  @@map("users")
}

model RevokedToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime @default(now()) @map("revoked_at")

  @@map("revoked_tokens")
}

model Person {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  name             String
  relationship     String
  birthday         DateTime?
  anniversary      DateTime?
  budgetMinCents   Int?      @map("budget_min_cents")
  budgetMaxCents   Int?      @map("budget_max_cents")
  clothingSizeTop  String?   @map("clothing_size_top")
  clothingSizeBottom String? @map("clothing_size_bottom")
  shoeSize         String?   @map("shoe_size")
  musicTaste       String?   @map("music_taste")
  favoriteBrands   String?   @map("favorite_brands")
  hobbies          String?
  foodPreferences  String?   @map("food_preferences")
  wishlistUrls     String?   @map("wishlist_urls")
  notes            String?
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user             User      @relation(fields: [userId], references: [id])
  neverAgainItems  NeverAgainItem[]
  events           Event[]

  @@index([userId, deletedAt])
  @@map("persons")
}

model NeverAgainItem {
  id        String   @id @default(uuid())
  personId  String   @map("person_id")
  description String
  createdAt DateTime @default(now()) @map("created_at")

  person    Person   @relation(fields: [personId], references: [id])

  @@map("never_again_items")
}

enum OccasionType {
  birthday
  anniversary
  holiday
  graduation
  promotion
  custom

  @@map("occasion_type")
}

enum RecurrenceRule {
  annual
  one_time @map("one_time")

  @@map("recurrence_rule")
}

model Event {
  id             String         @id @default(uuid())
  personId       String         @map("person_id")
  userId         String         @map("user_id")
  name           String
  occasionType   OccasionType   @map("occasion_type")
  date           DateTime       @db.Date
  isRecurring    Boolean        @default(false) @map("is_recurring")
  recurrenceRule RecurrenceRule @default(one_time) @map("recurrence_rule")
  budgetMinCents Int?           @map("budget_min_cents")
  budgetMaxCents Int?           @map("budget_max_cents")
  notes          String?
  isAutoCreated  Boolean        @default(false) @map("is_auto_created")
  userModified   Boolean        @default(false) @map("user_modified")
  userDeleted    Boolean        @default(false) @map("user_deleted")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  person    Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders Reminder[]

  @@unique([personId, occasionType, isAutoCreated], name: "uq_person_auto_event", map: "uq_person_auto_event")
  @@index([userId, date], map: "idx_events_user_date")
  @@index([personId], map: "idx_events_person")
  @@index([userId, occasionType], map: "idx_events_user_occasion")
  @@map("events")
}

model Reminder {
  id           String    @id @default(uuid())
  eventId      String    @map("event_id")
  userId       String    @map("user_id")
  leadDays     Int       @map("lead_days")
  scheduledFor DateTime  @map("scheduled_for") @db.Date
  dismissedAt  DateTime? @map("dismissed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, leadDays, scheduledFor], map: "uq_reminder_event_lead_scheduled")
  @@index([userId, dismissedAt, scheduledFor], map: "idx_reminders_user_active")
  @@map("reminders")
}
