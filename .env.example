# Broflo Environment Variables
# Copy to .env.local and fill in values
# All production secrets live in Azure Key Vault: cu2-apps-kv

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/broflo

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# JWT
JWT_SECRET=

# Anthropic AI
ANTHROPIC_API_KEY=

# Stripe (stub — activated in S-6)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Azure
AZURE_KEY_VAULT_URL=https://cu2-apps-kv.vault.azure.net/
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# OPS Platform
OPS_PLATFORM_API_KEY=
OPS_PLATFORM_URL=https://ops.cu2.app

# API URLs (local dev)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_URL=http://localhost:8000
