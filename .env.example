# Broflo Environment Variables
# Copy to .env.local and fill in values
# All production secrets live in Azure Key Vault: cu2-apps-kv

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/broflo

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# JWT
JWT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Broflo <noreply@broflo.com>

# Frontend URL (for CORS + OAuth redirects)
WEB_URL=http://localhost:3000

# Anthropic AI
ANTHROPIC_API_KEY=

# Stripe (S-6 — create products in Stripe dashboard, paste price IDs here)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ELITE_MONTHLY_PRICE_ID=
STRIPE_ELITE_ANNUAL_PRICE_ID=

# Stripe price IDs (frontend — must be NEXT_PUBLIC_ prefixed)
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_ELITE_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_ELITE_ANNUAL_PRICE_ID=

# Azure
AZURE_KEY_VAULT_URL=https://cu2-apps-kv.vault.azure.net/
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# OPS Platform
OPS_PLATFORM_API_KEY=
OPS_PLATFORM_URL=https://ops.cu-2.com

# API URLs (local dev)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_URL=http://localhost:8000
