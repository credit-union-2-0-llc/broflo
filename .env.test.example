E2E_ALPHA_EMAIL=
E2E_BETA_EMAIL=
E2E_GAMMA_EMAIL=
E2E_DELTA_EMAIL=

# Cross-browser target (defaults to localhost if unset)
BROFLO_BASE_URL=http://localhost:4000
BROFLO_API_URL=http://localhost:4002

# OTP test hatch — shared secret must match the target api's E2E_TEST_HATCH_TOKEN.
# For live runs, pull the token from Azure Key Vault (cu2-apps-kv).
E2E_TEST_HATCH_TOKEN=
